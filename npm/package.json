    },
    "x86_64-apple-darwin": {
      "artifactName": "baton-mcp-x86_64-apple-darwin.tar.xz",
      "bins": {
        "baton": "baton"
      },
      "zipExt": ".tar.xz"
    },
    "x86_64-pc-windows-gnu": {
      "artifactName": "baton-mcp-x86_64-pc-windows-msvc.zip",
      "bins": {
        "baton": "baton.exe"
      },
      "zipExt": ".zip"
